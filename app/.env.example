# ======================
# Timezone
# ======================
# Fixa o timezone do processo Node em horário de Brasília, independente de
# onde a aplicação rode (produção geralmente roda em UTC por padrão).
TZ="America/Sao_Paulo"

# ======================
# Banco de Dados
# ======================
# Connection pooler (transaction mode) - usado em runtime pela aplicação
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/barber?schema=public"
# Connection direta / session mode - usada pelo Prisma para rodar migrations
# (obrigatória ao usar um pooler como PgBouncer/Supabase; se estiver usando
# Postgres direto sem pooler, pode repetir o mesmo valor de DATABASE_URL)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/barber?schema=public"

# ======================
# NextAuth
# ======================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="coloque_uma_chave_segura_aqui"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ======================
# Twilio (WhatsApp Sandbox ou número aprovado)
# ======================
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
